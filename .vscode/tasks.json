{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Sync: Bump Version and Push",
            "detail": "Increments the patch version in pyproject.toml, commits the bump, tags the commit, then pulls and pushes with tags.",
            "type": "shell",
            "command": "bash",
            "args": ["${workspaceFolder}/.vscode/scripts/sync-version.sh"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true,
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
